{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": {
        "position": {
          "x": 20,
          "y": 200
        },
        "measured": {
          "width": 150,
          "height": 66
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "agent_rocketride_1",
      "provider": "agent_rocketride",
      "config": {
        "instructions": [
          "You are an HR assistant. Help users find information about employees.",
          "To look up employees, construct a GET request to: http://odoo:8069/api/v1/employees/search",
          "Append the search term as a URL query parameter: ?q=<search_term>",
          "Always include the HTTP header: X-Api-Key: ${ROCKETRIDE_ODOO_HR_API_KEY}",
          "Return clear, concise answers based on the employee data. If no employees match, say so."
        ],
        "max_waves": 3
      },
      "ui": {
        "position": {
          "x": 240,
          "y": 200
        },
        "measured": {
          "width": 150,
          "height": 86
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "chat_1"
        }
      ]
    },
    {
      "id": "llm_qwen_1",
      "provider": "llm_qwen",
      "config": {
        "model": "qwen-plus",
        "region": "intl",
        "apikey": "${ROCKETRIDE_QWEN_API_KEY}"
      },
      "ui": {
        "position": {
          "x": 130,
          "y": 360
        },
        "measured": {
          "width": 150,
          "height": 66
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "llm",
          "from": "agent_rocketride_1"
        }
      ]
    },
    {
      "id": "tool_http_request_1",
      "provider": "tool_http_request",
      "config": {
        "type": "tool_http_request",
        "allowGET": true,
        "allowPOST": false,
        "allowPUT": false,
        "allowPATCH": false,
        "allowDELETE": false,
        "allowHEAD": false,
        "allowOPTIONS": false,
        "urlWhitelist": [
          {
            "whitelistPattern": "^http://odoo:8069/api/v1/employees/search(\\?.*)?$"
          }
        ]
      },
      "ui": {
        "position": {
          "x": 300,
          "y": 360
        },
        "measured": {
          "width": 150,
          "height": 40
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_rocketride_1"
        }
      ]
    },
    {
      "id": "memory_internal_1",
      "provider": "memory_internal",
      "config": {
        "type": "memory_internal"
      },
      "ui": {
        "position": {
          "x": 470,
          "y": 360
        },
        "measured": {
          "width": 150,
          "height": 40
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "memory",
          "from": "agent_rocketride_1"
        }
      ]
    },
    {
      "id": "response_answers_1",
