    {
      "id": "agent_rocketride_1",
      "provider": "agent_rocketride",
      "config": {
        "instructions": [
          "You are a company assistant. Help users find information about employees and company data.",
          "You have access to Odoo MCP tools. Use the odoo_record_retriever tool to fetch data.",
          "Domain filters use direct field names only — never use dot-notation (e.g. use 'department_id' not 'department_id.name'). For employee queries, filter on 'name' or 'job_title'. To get all employees, use an empty domain [].",
          "If a tool call fails, retry with a simpler domain (e.g. []) before giving up.",
          "Return clear, concise answers. List employee names and their job titles or department."
        ],
        "max_waves": 3
      },
      "ui": {
        "position": {
          "x": 240,
          "y": 200
        },
        "measured": {
          "width": 150,
          "height": 108
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "chat_1"
        }
      ]
    },
    {
      "id": "llm_qwen_1",
      "provider": "llm_qwen",
      "config": {
        "model": "qwen-plus",
        "region": "intl",
        "apikey": "${ROCKETRIDE_QWEN_API_KEY}"
      },
      "ui": {
        "position": {
