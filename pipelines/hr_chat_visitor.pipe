{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": {
        "position": {
          "x": 20,
          "y": 200
        },
        "measured": {
          "width": 150,
          "height": 66
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "agent_rocketride_1",
      "provider": "agent_rocketride",
      "config": {
        "instructions": [
          "You are a company assistant. Help users find information about employees and company data.",
          "You have access to Odoo MCP tools. Use the odoo_record_retriever tool to fetch data.",
          "To list all employees use: model='hr.employee', fields=['name'], domain=[], limit=100. This returns a compact list of names.",
          "To get details for a specific employee use: domain=[['name','=','Employee Name']], fields=['name','job_title','department_id'].",
          "IMPORTANT: The tool response is a complete JSON array — every object is a valid complete record. Count and list ALL items.",
          "IMPORTANT: This is a stateless chatbot. Never ask follow-up questions. Answer directly and completely in a single response."
        ],
        "max_waves": 3
      },
      "ui": {
        "position": {
          "x": 240,
          "y": 200
        },
        "measured": {
          "width": 150,
          "height": 86
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "chat_1"
        }
      ]
    },
    {
      "id": "llm_qwen_1",
      "provider": "llm_qwen",
      "config": {
        "model": "qwen-plus",
        "region": "intl",
        "apikey": "${ROCKETRIDE_QWEN_API_KEY}"
      },
      "ui": {
        "position": {
          "x": 130,
          "y": 360
        },
        "measured": {
          "width": 150,
          "height": 66
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "llm",
          "from": "agent_rocketride_1"
        }
      ]
    },
    {
      "id": "mcp_client_1",
      "provider": "mcp_client",
      "config": {
        "type": "mcp_client",
        "serverName": "odoo",
        "transport": "streamable-http",
        "http": {
          "endpoint": "${ROCKETRIDE_MCP_ENDPOINT}",
          "headers": {},
          "bearer": "${ROCKETRIDE_MCP_VISITOR_KEY}"
        }
      },
      "ui": {
        "position": {
          "x": 300,
          "y": 360
        },
        "measured": {
