<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="chatbot_page" name="Chatbot Page">
        <t t-call="website.layout">
            <t t-set="title">AI Chatbot</t>
            <div id="chatbot-wrap" class="container py-4">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-8 col-lg-6">
                        <h4 class="mb-3">AI Assistant</h4>
                        <div id="chatbot-messages" class="chatbot-messages border rounded bg-white p-3 mb-3">
                            <div class="chatbot-bubble assistant">
                                <span>Hello! How can I help you today?</span>
                            </div>
                        </div>
                        <form id="chatbot-form" class="d-flex gap-2">
                            <input
                                id="chatbot-input"
                                type="text"
                                class="form-control"
                                placeholder="Type a message..."
                                autocomplete="off"
                            />
                            <button id="chatbot-send" type="submit" class="btn btn-primary">Send</button>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
